#include <stdio.h>
#include <string.h>

int main()
{
    char str[100], rev[100];
    int choice, i, length, count;

    printf("Enter a string: ");
    gets(str);

    do
    {
        printf("\n===== String Operation System =====");
        printf("\n1. Find String Length");
        printf("\n2. Reverse String");
        printf("\n3. Check Palindrome");
        printf("\n4. Count Vowels");
        printf("\n5. Convert Lowercase to Uppercase");
        printf("\n6. Exit");

        printf("\nEnter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                length = strlen(str);
                printf("Length of string = %d", length);
                break;

            case 2:
                length = strlen(str);

                for(i = 0; i < length; i++)
                {
                    rev[i] = str[length - i - 1];
                }

                rev[length] = '\0';

                printf("Reverse string = %s", rev);
                break;

            case 3:
                length = strlen(str);
                count = 1;

                for(i = 0; i < length / 2; i++)
                {
                    if(str[i] != str[length - i - 1])
                    {
                        count = 0;
                        break;
                    }
                }

                if(count == 1)
                    printf("String is Palindrome");
                else
                    printf("String is not Palindrome");

                break;

            case 4:
                count = 0;

                for(i = 0; str[i] != '\0'; i++)
                {
                    if(str[i]=='a'||str[i]=='e'||str[i]=='i'||
                       str[i]=='o'||str[i]=='u'||
                       str[i]=='A'||str[i]=='E'||str[i]=='I'||
                       str[i]=='O'||str[i]=='U')
                    {
                        count++;
                    }
                }

                printf("Number of vowels = %d", count);
                break;

            case 5:
                for(i = 0; str[i] != '\0'; i++)
                {
                    if(str[i] >= 'a' && str[i] <= 'z')
                    {
                        str[i] = str[i] - 32;
                    }
                }

                printf("Uppercase string = %s", str);
                break;

            case 6:
                printf("Exiting program...");
                break;

            default:
                printf("Invalid choice");
        }

    } while(choice != 6);

    return 0;
}

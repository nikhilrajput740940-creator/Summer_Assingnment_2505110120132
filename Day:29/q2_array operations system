#include <stdio.h>

int main()
{
    int arr[100], n, i, choice, sum, max, min, search, found;

    printf("Enter size of array: ");
    scanf("%d", &n);

    printf("Enter array elements:\n");

    for(i = 0; i < n; i++)
    {
        scanf("%d", &arr[i]);
    }

    do
    {
        printf("\n===== Array Operation System =====");
        printf("\n1. Display Array");
        printf("\n2. Find Sum");
        printf("\n3. Find Maximum Element");
        printf("\n4. Find Minimum Element");
        printf("\n5. Linear Search");
        printf("\n6. Exit");

        printf("\nEnter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                printf("Array elements are:\n");
                for(i = 0; i < n; i++)
                {
                    printf("%d ", arr[i]);
                }
                break;

            case 2:
                sum = 0;

                for(i = 0; i < n; i++)
                {
                    sum = sum + arr[i];
                }

                printf("Sum of array = %d", sum);
                break;

            case 3:
                max = arr[0];

                for(i = 1; i < n; i++)
                {
                    if(arr[i] > max)
                    {
                        max = arr[i];
                    }
                }

                printf("Maximum element = %d", max);
                break;

            case 4:
                min = arr[0];

                for(i = 1; i < n; i++)
                {
                    if(arr[i] < min)
                    {
                        min = arr[i];
                    }
                }

                printf("Minimum element = %d", min);
                break;

            case 5:
                printf("Enter element to search: ");
                scanf("%d", &search);

                found = 0;

                for(i = 0; i < n; i++)
                {
                    if(arr[i] == search)
                    {
                        found = 1;
                        break;
                    }
                }

                if(found == 1)
                    printf("Element found at position %d", i + 1);
                else
                    printf("Element not found");

                break;

            case 6:
                printf("Exiting program...");
                break;

            default:
                printf("Invalid choice");
        }

    } while(choice != 6);

    return 0;
}

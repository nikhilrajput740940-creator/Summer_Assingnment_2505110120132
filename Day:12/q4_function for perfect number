#include <stdio.h>

// Function declaration
int perfect(int n);

int main()
{
    int num, result;

    printf("Enter a number: ");
    scanf("%d", &num);

    result = perfect(num);

    if(result == 1)
        printf("%d is a Perfect number", num);
    else
        printf("%d is not a Perfect number", num);

    return 0;
}

// Function definition
int perfect(int n)
{
    int i, sum = 0;

    for(i = 1; i < n; i++)
    {
        if(n % i == 0)
        {
            sum = sum + i;
        }
    }

    if(sum == n)
        return 1;
    else
        return 0;
}

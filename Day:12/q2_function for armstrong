#include <stdio.h>

// Function declaration
int armstrong(int n);

int main()
{
    int num, result;

    printf("Enter a number: ");
    scanf("%d", &num);

    result = armstrong(num);

    if(result == 1)
        printf("%d is an Armstrong number", num);
    else
        printf("%d is not an Armstrong number", num);

    return 0;
}

// Function definition
int armstrong(int n)
{
    int original, sum = 0, rem;

    original = n;

    while(n != 0)
    {
        rem = n % 10;
        sum = sum + (rem * rem * rem);
        n = n / 10;
    }

    if(original == sum)
        return 1;
    else
        return 0;
}

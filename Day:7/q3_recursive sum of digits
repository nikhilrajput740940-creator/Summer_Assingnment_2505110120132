#include <stdio.h>

int sumOfDigits(int n) {
    if(n == 0) {
        return 0;   // Base condition
    }
    else {
        return (n % 10) + sumOfDigits(n / 10); // Recursive call
    }
}

int main() {
    int n;

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("Sum of digits = %d", sumOfDigits(n));

    return 0;
}

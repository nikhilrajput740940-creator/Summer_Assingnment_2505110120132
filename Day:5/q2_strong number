#include <stdio.h>

int main() {
    int n, original, digit, sum = 0, fact;

    printf("Enter a number: ");
    scanf("%d", &n);

    original = n;

    while(n != 0) {
        digit = n % 10;
        fact = 1;

        for(int i = 1; i <= digit; i++) {
            fact = fact * i;
        }

        sum = sum + fact;
        n = n / 10;
    }

    if(sum == original) {
        printf("The number is a Strong Number");
    }
    else {
        printf("The number is not a Strong Number");
    }

    return 0;
}

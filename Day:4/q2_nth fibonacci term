#include <stdio.h>

int main() {
    int n, first = 0, second = 1, next;

    printf("Enter the term number: ");
    scanf("%d", &n);

    if(n == 0) {
        printf("Fibonacci term = 0");
    }
    else if(n == 1) {
        printf("Fibonacci term = 1");
    }
    else {
        for(int i = 2; i <= n; i++) {
            next = first + second;
            first = second;
            second = next;
        }

        printf("Fibonacci term at position %d = %d", n, second);
    }

    return 0;
}

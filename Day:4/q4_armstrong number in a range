#include <stdio.h>

int main() {
    int start, end, num, original, digit, sum;

    printf("Enter starting range: ");
    scanf("%d", &start);

    printf("Enter ending range: ");
    scanf("%d", &end);

    printf("Armstrong numbers between %d and %d are:\n", start, end);

    for(num = start; num <= end; num++) {

        original = num;
        sum = 0;

        while(num != 0) {
            digit = num % 10;
            sum = sum + (digit * digit * digit);
            num = num / 10;
        }

        if(sum == original) {
            printf("%d ", original);
        }

        num = original;
    }

    return 0;
}

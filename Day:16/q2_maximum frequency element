#include <stdio.h>

int main()
{
    int arr[100], n, i;
    int sum = 0, total;

    printf("Enter the size of array: ");
    scanf("%d", &n);

    printf("Enter %d elements:\n", n - 1);

    for(i = 0; i < n - 1; i++)
    {
        scanf("%d", &arr[i]);
        sum = sum + arr[i];
    }

    // Sum of numbers from 1 to n
    total = n * (n + 1) / 2;

    printf("Missing number = %d", total - sum);

    return 0;
}

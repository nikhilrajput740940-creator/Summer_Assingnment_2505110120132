#include <stdio.h>
#include <string.h>

int main()
{
    int id[100], n, i, search, found = 0;
    char book[100][50];

    printf("Enter number of books: ");
    scanf("%d", &n);

    // Input book details
    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of book %d\n", i + 1);

        printf("Enter Book ID: ");
        scanf("%d", &id[i]);

        printf("Enter Book Name: ");
        scanf("%s", book[i]);
    }

    // Display books
    printf("\n===== Library Books =====\n");

    printf("Book ID\tBook Name\n");

    for(i = 0; i < n; i++)
    {
        printf("%d\t%s\n", id[i], book[i]);
    }

    // Search book
    printf("\nEnter Book ID to search: ");
    scanf("%d", &search);

    for(i = 0; i < n; i++)
    {
        if(id[i] == search)
        {
            printf("\nBook Found!");
            printf("\nBook ID: %d", id[i]);
            printf("\nBook Name: %s", book[i]);
            found = 1;
            break;
        }
    }

    if(found == 0)
    {
        printf("\nBook not found.");
    }

    return 0;
}

#include <stdio.h>

int main() {
    int start, end, i, j, isPrime;

    printf("Enter starting range: ");
    scanf("%d", &start);

    printf("Enter ending range: ");
    scanf("%d", &end);

    printf("Prime numbers between %d and %d are: ", start, end);

    for(i = start; i <= end; i++) {
        isPrime = 1;

        if(i <= 1) {
            isPrime = 0;
        }

        for(j = 2; j < i; j++) {
            if(i % j == 0) {
                isPrime = 0;
                break;
            }
        }

        if(isPrime == 1) {
            printf("%d ", i);
        }
    }

    return 0;
}


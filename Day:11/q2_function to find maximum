#include <stdio.h>

// Function declaration
int maximum(int a, int b);

int main()
{
    int num1, num2, max;

    printf("Enter two numbers: ");
    scanf("%d %d", &num1, &num2);

    max = maximum(num1, num2);

    printf("Maximum number = %d", max);

    return 0;
}

// Function definition
int maximum(int a, int b)
{
    if(a > b)
        return a;
    else
        return b;
}

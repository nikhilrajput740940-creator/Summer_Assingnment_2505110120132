#include <stdio.h>

// Function declaration
int sum(int a, int b);

int main()
{
    int num1, num2, result;

    printf("Enter two numbers: ");
    scanf("%d %d", &num1, &num2);

    result = sum(num1, num2);

    printf("Sum of two numbers = %d", result);

    return 0;
}

// Function definition
int sum(int a, int b)
{
    return a + b;
}

#include <stdio.h>

int main() {
    int n, reverse = 0, digit;

    printf("Enter a number: ");
    scanf("%d", &n);

    while(n != 0) {
        digit = n % 10;                 // Get last digit
        reverse = reverse * 10 + digit; // Add digit to reverse
        n = n / 10;                     // Remove last digit
    }

    printf("Reverse of the number = %d", reverse);

    return 0;
}

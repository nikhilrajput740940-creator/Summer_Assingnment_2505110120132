#include <stdio.h>

int main()
{
    int matrix[10][10];
    int n, i, j, sum = 0;

    printf("Enter the size of square matrix: ");
    scanf("%d", &n);

    printf("Enter elements of matrix:\n");

    for(i = 0; i < n; i++)
    {
        for(j = 0; j < n; j++)
        {
            scanf("%d", &matrix[i][j]);
        }
    }

    // Finding diagonal sum
    for(i = 0; i < n; i++)
    {
        sum = sum + matrix[i][i];
    }

    printf("Sum of diagonal elements = %d", sum);

    return 0;
}

#include <stdio.h>

struct Student
{
    int roll;
    char name[50];
    float marks1, marks2, marks3;
    float total;
    float percentage;
};

int main()
{
    struct Student s[100];
    int n, i;

    printf("Enter number of students: ");
    scanf("%d", &n);

    // Input student details
    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of student %d\n", i + 1);

        printf("Enter Roll Number: ");
        scanf("%d", &s[i].roll);

        printf("Enter Name: ");
        scanf("%s", s[i].name);

        printf("Enter marks of three subjects:\n");
        scanf("%f %f %f", &s[i].marks1, &s[i].marks2, &s[i].marks3);

        // Calculate total and percentage
        s[i].total = s[i].marks1 + s[i].marks2 + s[i].marks3;
        s[i].percentage = s[i].total / 3;
    }

    // Display marksheet
    printf("\n===== Student Marksheet =====\n");

    for(i = 0; i < n; i++)
    {
        printf("\nRoll Number: %d", s[i].roll);
        printf("\nName: %s", s[i].name);
        printf("\nSubject 1 Marks: %.2f", s[i].marks1);
        printf("\nSubject 2 Marks: %.2f", s[i].marks2);
        printf("\nSubject 3 Marks: %.2f", s[i].marks3);
        printf("\nTotal Marks: %.2f", s[i].total);
        printf("\nPercentage: %.2f%%\n", s[i].percentage);

        if(s[i].percentage >= 40)
            printf("Result: PASS\n");
        else
            printf("Result: FAIL\n");
    }

    return 0;
}

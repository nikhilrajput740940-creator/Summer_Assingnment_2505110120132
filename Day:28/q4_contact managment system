#include <stdio.h>

struct Contact
{
    char name[50];
    char phone[15];
    char email[50];
};

int main()
{
    struct Contact contact[100];
    int n, i;

    printf("Enter number of contacts: ");
    scanf("%d", &n);

    // Input contact details
    for(i = 0; i < n; i++)
    {
        printf("\nEnter details of contact %d\n", i + 1);

        printf("Enter Name: ");
        scanf("%s", contact[i].name);

        printf("Enter Phone Number: ");
        scanf("%s", contact[i].phone);

        printf("Enter Email: ");
        scanf("%s", contact[i].email);
    }

    // Display contact details
    printf("\n===== Contact List =====\n");

    for(i = 0; i < n; i++)
    {
        printf("\nContact %d", i + 1);
        printf("\nName: %s", contact[i].name);
        printf("\nPhone: %s", contact[i].phone);
        printf("\nEmail: %s\n", contact[i].email);
    }

    return 0;
}

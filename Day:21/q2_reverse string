#include <stdio.h>

int main()
{
    char str[100], reverse[100];
    int i, length = 0;

    printf("Enter a string: ");
    gets(str);

    // Find length of string
    while(str[length] != '\0')
    {
        length++;
    }

    // Reverse string
    for(i = 0; i < length; i++)
    {
        reverse[i] = str[length - i - 1];
    }

    reverse[length] = '\0';

    printf("Reverse string is: %s", reverse);

    return 0;
}
